{
  "$schema": "../schema.json",
  "service": {
    "name": "payments-api",
    "team": "payments",
    "repository": "org/payments-api"
  },
  "target": {
    "platform": "appengine",
    "gcp_project_id": "myorg-staging",
    "region": "us-central1"
  },
  "environments": {
    "staging": {
      "gcp_project_id": "myorg-staging",
      "variables": {
        "NODE_ENV": "staging",
        "LOG_LEVEL": "debug",
        "API_BASE_URL": "https://api-staging.example.com"
      }
    },
    "production": {
      "gcp_project_id": "myorg-production",
      "variables": {
        "NODE_ENV": "production",
        "LOG_LEVEL": "warn",
        "API_BASE_URL": "https://api.example.com"
      },
      "requires_approval": true
    }
  },
  "build": {
    "runtime": "nodejs22",
    "build_command": "npm run build",
    "artifact_path": "./dist"
  },
  "deploy": {
    "health_check_path": "/health",
    "min_instances": 1,
    "max_instances": 5,
    "timeout_seconds": 300
  },
  "platform_config": {
    "service_id": "payments-api",
    "instance_class": "F2",
    "automatic_scaling": {
      "min_idle_instances": 1,
      "max_idle_instances": "automatic",
      "min_pending_latency": "30ms",
      "max_pending_latency": "automatic"
    }
  }
}
